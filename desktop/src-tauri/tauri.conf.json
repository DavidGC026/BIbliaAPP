{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BibliaAPP",
  "version": "0.3.1",
  "identifier": "com.bibliaapp.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BibliaAPP",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["bibliaapp"]
      }
    },
    "updater": {
      "endpoints": [
        "https://biblia2.dvguzman.com/desktop/releases/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYyRkNBMzk5OTk0OUYxRjkKUldUNThVbVptYVA4OHQ3d29tU1VkbWRDL2lZMi9MWW90UnpDUXRrY0hORWs2QlRsWmxUV282amMK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
