{
  "name": "bibliaapp-desktop",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "tsx src/lib/__check__.ts",
    "icons": "cp ../public/logo.png app-icon.png 2>/dev/null || cp ../../public/logo.png app-icon.png; cp app-icon.png public/logo.png; tauri icon app-icon.png",
    "build:arch": "tauri build",
    "build:deb": "tauri build --bundles deb",
    "build:win": "tauri build --bundles msi,nsis",
    "pack:arch": "npm run icons && npm run build:arch && ./packaging/arch/build-pacman-pkg.sh",
    "pack:deb": "npm run icons && npm run build:deb",
    "pack:win": "npm run icons && npm run build:win",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
